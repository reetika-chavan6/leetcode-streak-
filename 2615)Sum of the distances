BY using dictionary too

class Solution(object):
    def distance(self, nums):
        from collections import defaultdict
        pos = defaultdict(list)
        for i in range(len(nums)):
            pos[nums[i]].append(i)
        res = [0] * len(nums)
        for num in pos:
            indices = pos[num]
            for i in indices:
                total = 0
                for j in indices:
                    total += abs(i - j)
                res[i] = total
        return res
