//This is the crt way to slove the problem with least time complexity
class Solution(object):
    def distance(self, nums):
        from collections import defaultdict
        pos=defaultdict(list)
        for i in range(len(nums)):
            pos[nums[i]].append(i)
        res=[0]*len(nums)
        for indices in pos.values():
            prefix = 0
            total = sum(indices)
            n = len(indices)
            for i in range(n):
                idx =indices[i]
                left =idx*i-prefix
                right =(total-prefix-idx)-(n-i-1) * idx
                res[idx] = left+right
                prefix+=idx
        return res
// The another way to slove this problems but with more time complexity are
class Solution(object):
    def distance(self, nums):
        n = len(nums)
        ans = []
        for i in range(n):
            total = 0
            for j in range(n):
                if nums[i] == nums[j]:
                    total += abs(i - j)
            ans.append(total)
        return ans

